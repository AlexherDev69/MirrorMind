{
  "name": "phone-stream-to-windows",
  "version": "0.1.0",
  "private": true,
  "description": "Stream your phone screen to Windows and expose it to Claude Code via MCP",
  "scripts": {
    "dev": "pnpm build:mcp && pnpm --filter @phone-stream/app tauri dev",
    "build": "pnpm build:mcp && pnpm --filter @phone-stream/app tauri build",
    "dev:frontend": "pnpm --filter @phone-stream/app dev",
    "build:frontend": "pnpm --filter @phone-stream/app build",
    "build:shared": "pnpm --filter @phone-stream/shared build",
    "build:mcp": "pnpm build:shared && pnpm --filter @phone-stream/mcp-server build",
    "dev:mcp": "pnpm --filter @phone-stream/mcp-server dev",
    "setup:mcp": "pnpm --filter @phone-stream/mcp-server setup:mcp",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "knip": "^6.1.1",
    "typescript": "^6.0.2"
  }
}
