{
  "name": "@phone-stream/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "kill-port": "node -e \"const{execSync}=require('child_process');[':1420',':17395'].forEach(p=>{try{const r=execSync('netstat -ano').toString().split('\\n').find(l=>l.includes(p)&&l.includes('LISTENING'));if(r){const pid=r.trim().split(/\\s+/).pop();execSync('taskkill /F /PID '+pid)}}catch{}})\"",
    "dev": "pnpm kill-port && vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@phone-stream/shared": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.1"
  }
}
