{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MirrorMind",
  "version": "0.1.0",
  "identifier": "com.phonestream.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MirrorMind",
        "width": 420,
        "height": 900,
        "minWidth": 320,
        "minHeight": 568,
        "resizable": true,
        "center": false,
        "focus": true,
        "visible": false,
        "decorations": true,
        "skipTaskbar": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' http://127.0.0.1:17395; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../public/assets/scrcpy-server.jar": "assets/scrcpy-server.jar",
      "mcp-bundle": "mcp-server"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
